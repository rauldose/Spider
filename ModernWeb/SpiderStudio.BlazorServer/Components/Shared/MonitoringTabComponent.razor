@using Spider.DeviceManagement.Application.DTOs
@using Spider.DataAcquisition.Application.DTOs
@using SpiderStudio.BlazorServer.Services
@inject IJSRuntime JSRuntime
@implements IDisposable

<div class="monitoring-tab">
    <div class="row">
        <div class="col-12">
            <h5 class="border-bottom pb-2 mb-4">
                <i class="bi bi-graph-up me-2"></i>Real-time Monitoring
            </h5>
        </div>
    </div>

    <!-- Control Panel -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-md-4">
                            <div class="d-flex align-items-center gap-3">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" @bind="_isMonitoring" 
                                           @onchange="ToggleMonitoring" id="monitoringSwitch">
                                    <label class="form-check-label" for="monitoringSwitch">
                                        Real-time Monitoring
                                    </label>
                                </div>
                                <div class="status-indicator">
                                    @if (_isMonitoring)
                                    {
                                        <span class="badge bg-success">
                                            <i class="bi bi-broadcast me-1"></i>Live
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">
                                            <i class="bi bi-pause me-1"></i>Stopped
                                        </span>
                                    }
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="d-flex align-items-center gap-2">
                                <label class="form-label mb-0">Update Interval:</label>
                                <select class="form-select form-select-sm" style="width: auto;" @bind="_updateInterval">
                                    <option value="1000">1 second</option>
                                    <option value="2000">2 seconds</option>
                                    <option value="5000">5 seconds</option>
                                    <option value="10000">10 seconds</option>
                                    <option value="30000">30 seconds</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="text-end">
                                <small class="text-muted">
                                    Last Update: @(_lastUpdate?.ToString("HH:mm:ss") ?? "Never")
                                </small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <i class="bi bi-tags text-primary fs-1"></i>
                    <h5 class="card-title mt-2">@DataPoints.Count</h5>
                    <p class="card-text text-muted">Total Data Points</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <i class="bi bi-check-circle text-success fs-1"></i>
                    <h5 class="card-title mt-2">@_goodQualityCount</h5>
                    <p class="card-text text-muted">Good Quality</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <i class="bi bi-exclamation-triangle text-warning fs-1"></i>
                    <h5 class="card-title mt-2">@_uncertainQualityCount</h5>
                    <p class="card-text text-muted">Uncertain Quality</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <i class="bi bi-x-circle text-danger fs-1"></i>
                    <h5 class="card-title mt-2">@_badQualityCount</h5>
                    <p class="card-text text-muted">Bad Quality</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Real-time Data Grid -->
    <div class="card">
        <div class="card-header">
            <div class="d-flex justify-content-between align-items-center">
                <h6 class="mb-0">
                    <i class="bi bi-speedometer2 me-2"></i>Live Data Values
                </h6>
                <div class="d-flex gap-2">
                    <button class="btn btn-outline-secondary btn-sm" @onclick="RefreshData">
                        <i class="bi bi-arrow-clockwise me-1"></i>Refresh
                    </button>
                    <button class="btn btn-outline-primary btn-sm" @onclick="ExportSnapshot">
                        <i class="bi bi-camera me-1"></i>Snapshot
                    </button>
                </div>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive" style="max-height: 500px;">
                <table class="table table-hover table-sm mb-0">
                    <thead class="table-dark sticky-top">
                        <tr>
                            <th>Name</th>
                            <th>Address</th>
                            <th>Current Value</th>
                            <th>Previous Value</th>
                            <th>Change</th>
                            <th>Quality</th>
                            <th>Timestamp</th>
                            <th width="100">Trend</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (DataPoints.Any())
                        {
                            @foreach (var dataPoint in DataPoints.OrderBy(dp => dp.Name))
                            {
                                <tr class="@GetRowClass(dataPoint)">
                                    <td>
                                        <strong>@dataPoint.Name</strong>
                                    </td>
                                    <td>
                                        <code class="small">@dataPoint.Address</code>
                                    </td>
                                    <td>
                                        <span class="font-monospace fw-bold @GetValueClass(dataPoint)">
                                            @FormatValue(dataPoint.Value, dataPoint.DataType)
                                        </span>
                                    </td>
                                    <td>
                                        <span class="font-monospace text-muted">
                                            @FormatValue(GetPreviousValue(dataPoint), dataPoint.DataType)
                                        </span>
                                    </td>
                                    <td>
                                        @{
                                            var change = GetValueChange(dataPoint);
                                        }
                                        @if (change.HasValue)
                                        {
                                            <span class="badge @(change > 0 ? "bg-success" : change < 0 ? "bg-danger" : "bg-secondary")">
                                                @(change > 0 ? "+" : "")@change.Value.ToString("F2")
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge @GetQualityBadgeClass(dataPoint.Quality)">
                                            @dataPoint.Quality
                                        </span>
                                    </td>
                                    <td>
                                        <small class="@GetTimestampClass(dataPoint)">
                                            @(dataPoint.Timestamp?.ToString("HH:mm:ss.fff") ?? "Never")
                                        </small>
                                    </td>
                                    <td>
                                        <div class="sparkline" style="height: 30px; width: 80px;">
                                            @* Mini trend chart placeholder *@
                                            <small class="text-muted">Chart</small>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-4">
                                    <i class="bi bi-graph-down fs-1"></i>
                                    <p class="mt-2">No data points available for monitoring.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public DeviceDto Device { get; set; } = new();
    [Parameter] public List<DataPointDto> DataPoints { get; set; } = new();

    private bool _isMonitoring = false;
    private int _updateInterval = 5000; // 5 seconds
    private DateTime? _lastUpdate;
    private Timer? _monitoringTimer;
    
    private Dictionary<Guid, List<object?>> _valueHistory = new();
    private Dictionary<Guid, object?> _previousValues = new();

    private int _goodQualityCount => DataPoints.Count(dp => dp.Quality == "Good");
    private int _uncertainQualityCount => DataPoints.Count(dp => dp.Quality == "Uncertain");
    private int _badQualityCount => DataPoints.Count(dp => dp.Quality == "Bad");

    protected override void OnInitialized()
    {
        InitializeValueHistory();
    }

    public void Dispose()
    {
        _monitoringTimer?.Dispose();
    }

    private void InitializeValueHistory()
    {
        foreach (var dataPoint in DataPoints)
        {
            if (!_valueHistory.ContainsKey(dataPoint.Id))
            {
                _valueHistory[dataPoint.Id] = new List<object?>();
            }
        }
    }

    private async Task ToggleMonitoring()
    {
        if (_isMonitoring)
        {
            // Start monitoring
            _monitoringTimer = new Timer(async _ => await UpdateValues(), null, 0, _updateInterval);
        }
        else
        {
            // Stop monitoring
            _monitoringTimer?.Dispose();
            _monitoringTimer = null;
        }
        
        StateHasChanged();
    }

    private async Task UpdateValues()
    {
        try
        {
            // Store previous values
            foreach (var dataPoint in DataPoints)
            {
                _previousValues[dataPoint.Id] = dataPoint.Value;
            }

            // Simulate data updates (replace with actual API calls)
            var random = new Random();
            foreach (var dataPoint in DataPoints)
            {
                if (dataPoint.DataType == "Float" || dataPoint.DataType == "Integer")
                {
                    var currentValue = Convert.ToDouble(dataPoint.Value ?? 0);
                    var newValue = currentValue + (random.NextDouble() - 0.5) * 10; // Random variation
                    dataPoint.Value = Math.Round(newValue, 2);
                    
                    // Update history
                    var history = _valueHistory[dataPoint.Id];
                    history.Add(dataPoint.Value);
                    if (history.Count > 50) // Keep last 50 values
                    {
                        history.RemoveAt(0);
                    }
                }
                else if (dataPoint.DataType == "Boolean")
                {
                    dataPoint.Value = random.Next(2) == 1;
                }
                
                dataPoint.Timestamp = DateTime.Now;
                dataPoint.Quality = random.Next(10) < 8 ? "Good" : (random.Next(2) == 0 ? "Uncertain" : "Bad");
            }

            _lastUpdate = DateTime.Now;
            
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            // Handle error
        }
    }

    private async Task RefreshData()
    {
        await UpdateValues();
    }

    private async Task ExportSnapshot()
    {
        var snapshot = new
        {
            Timestamp = DateTime.Now,
            Device = Device.Name,
            DataPoints = DataPoints.Select(dp => new
            {
                dp.Name,
                dp.Address,
                dp.Value,
                dp.Quality,
                dp.Timestamp
            })
        };
        
        var json = System.Text.Json.JsonSerializer.Serialize(snapshot, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        await JSRuntime.InvokeVoidAsync("downloadFile", "data_snapshot.json", "application/json", json);
    }

    private object? GetPreviousValue(DataPointDto dataPoint)
    {
        return _previousValues.TryGetValue(dataPoint.Id, out var prevValue) ? prevValue : null;
    }

    private double? GetValueChange(DataPointDto dataPoint)
    {
        var current = dataPoint.Value;
        var previous = GetPreviousValue(dataPoint);
        
        if (current != null && previous != null && 
            double.TryParse(current.ToString(), out var currentNum) && 
            double.TryParse(previous.ToString(), out var previousNum))
        {
            return currentNum - previousNum;
        }
        
        return null;
    }

    private string FormatValue(object? value, string dataType)
    {
        if (value == null) return "null";
        
        return dataType switch
        {
            "Float" => $"{value:F2}",
            "Integer" => $"{value:F0}",
            "Boolean" => value.ToString()?.ToUpper() ?? "FALSE",
            "DateTime" => value is DateTime dt ? dt.ToString("yyyy-MM-dd HH:mm:ss") : value.ToString() ?? "",
            _ => value.ToString() ?? ""
        };
    }

    private string GetRowClass(DataPointDto dataPoint)
    {
        var ageInSeconds = dataPoint.Timestamp.HasValue 
            ? (DateTime.Now - dataPoint.Timestamp.Value).TotalSeconds 
            : double.MaxValue;
            
        return dataPoint.Quality switch
        {
            "Bad" => "table-danger",
            "Uncertain" => "table-warning",
            _ when ageInSeconds > 30 => "table-secondary", // Stale data
            _ => ""
        };
    }

    private string GetValueClass(DataPointDto dataPoint)
    {
        var change = GetValueChange(dataPoint);
        if (change.HasValue)
        {
            return change > 0 ? "text-success" : change < 0 ? "text-danger" : "";
        }
        return "";
    }

    private string GetQualityBadgeClass(string quality)
    {
        return quality switch
        {
            "Good" => "bg-success",
            "Bad" => "bg-danger",
            "Uncertain" => "bg-warning",
            _ => "bg-secondary"
        };
    }

    private string GetTimestampClass(DataPointDto dataPoint)
    {
        if (!dataPoint.Timestamp.HasValue) return "text-muted";
        
        var ageInSeconds = (DateTime.Now - dataPoint.Timestamp.Value).TotalSeconds;
        return ageInSeconds switch
        {
            < 5 => "text-success",
            < 30 => "text-primary",
            < 60 => "text-warning",
            _ => "text-danger"
        };
    }
}