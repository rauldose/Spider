@using Spider.DeviceManagement.Application.DTOs
@using Spider.ProjectManagement.Application.DTOs
@using SpiderStudio.BlazorServer.Services
@inject DeviceManagementApiService DeviceApi
@inject ProjectManagementApiService ProjectApi
@inject NavigationManager Navigation
@inject ILogger<ProjectTreeComponent> Logger

<div class="project-tree">
    @if (_projects.Any())
    {
        @foreach (var project in _projects.Where(p => p.ParentProjectId == null))
        {
            @RenderProjectNode(project)
        }
    }
    else
    {
        <!-- No projects message -->
        <div class="tree-node">
            <div class="tree-item">
                <i class="bi bi-folder tree-icon"></i>
                <span class="tree-text text-muted">No projects found</span>
            </div>
            <div class="tree-children">
                <div class="tree-node">
                    <div class="tree-item" @onclick='() => NavigateToPath("/projects")'>
                        <i class="bi bi-plus-circle tree-icon"></i>
                        <span class="tree-text">Create Project</span>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private RenderFragment RenderProjectNode(ProjectDto project) => __builder =>
    {
        <div class="tree-node">
            <div class="tree-item @(IsSelected($"project-{project.Id}") ? "selected" : "")" @onclick='() => ToggleNode($"project-{project.Id}")'>
                <i class="bi @(IsExpanded($"project-{project.Id}") ? "bi-folder2-open" : "bi-folder2") tree-icon"></i>
                <span class="tree-text">@project.Name</span>
                <span class="project-status @(project.Status.ToLower())">@project.Status[0]</span>
            </div>
            
            @if (IsExpanded($"project-{project.Id}"))
            {
                <div class="tree-children">
                    <!-- Child Projects -->
                    @if (project.ChildProjects.Any())
                    {
                        <div class="tree-node">
                            <div class="tree-item" @onclick='() => ToggleNode($"subprojects-{project.Id}")'>
                                <i class="bi @(IsExpanded($"subprojects-{project.Id}") ? "bi-folder2-open" : "bi-folder2") tree-icon"></i>
                                <span class="tree-text">Sub Projects (@project.ChildProjects.Count)</span>
                            </div>
                            @if (IsExpanded($"subprojects-{project.Id}"))
                            {
                                <div class="tree-children">
                                    @foreach (var childProject in project.ChildProjects)
                                    {
                                        @RenderProjectNode(childProject)
                                    }
                                </div>
                            }
                        </div>
                    }

                    <!-- Devices Node -->
                    <div class="tree-node">
                        <div class="tree-item" @onclick='() => ToggleNode($"devices-{project.Id}")'>
                            <i class="bi @(IsExpanded($"devices-{project.Id}") ? "bi-folder2-open" : "bi-folder2") tree-icon"></i>
                            <span class="tree-text">Devices</span>
                        </div>
                        
                        @if (IsExpanded($"devices-{project.Id}"))
                        {
                            <div class="tree-children">
                                @foreach (var device in _devices.Where(d => d.ProjectId == project.Id))
                                {
                                    <div class="tree-node device-node">
                                        <div class="tree-item @(IsSelected($"device-{device.Id}") ? "selected" : "")" 
                                             @onclick="() => SelectDevice(device)">
                                            <i class="bi bi-cpu tree-icon"></i>
                                            <span class="tree-text">@device.Name</span>
                                            <span class="device-status @(device.Status == "Connected" ? "online" : "offline")"></span>
                                        </div>
                                    </div>
                                }
                                @if (!_devices.Any(d => d.ProjectId == project.Id))
                                {
                                    <div class="tree-node">
                                        <div class="tree-item" @onclick='() => NavigateToPath("/devices")'>
                                            <i class="bi bi-plus-circle tree-icon"></i>
                                            <span class="tree-text text-muted">Add Device</span>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <!-- Connections Node -->
                    <div class="tree-node">
                        <div class="tree-item" @onclick='() => ToggleNode($"connections-{project.Id}")'>
                            <i class="bi @(IsExpanded($"connections-{project.Id}") ? "bi-folder2-open" : "bi-folder2") tree-icon"></i>
                            <span class="tree-text">Connections</span>
                        </div>
                        
                        @if (IsExpanded($"connections-{project.Id}"))
                        {
                            <div class="tree-children">
                                <div class="tree-node">
                                    <div class="tree-item" @onclick='() => NavigateToPath("/connections")'>
                                        <i class="bi bi-link tree-icon"></i>
                                        <span class="tree-text">Manage Connections</span>
                                    </div>
                                </div>
                                <div class="tree-node">
                                    <div class="tree-item" @onclick='() => NavigateToPath("/communication")'>
                                        <i class="bi bi-broadcast tree-icon"></i>
                                        <span class="tree-text">Communication</span>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Management Node -->
                    <div class="tree-node">
                        <div class="tree-item" @onclick='() => ToggleNode($"management-{project.Id}")'>
                            <i class="bi @(IsExpanded($"management-{project.Id}") ? "bi-folder2-open" : "bi-folder2") tree-icon"></i>
                            <span class="tree-text">Management</span>
                        </div>
                        
                        @if (IsExpanded($"management-{project.Id}"))
                        {
                            <div class="tree-children">
                                <div class="tree-node">
                                    <div class="tree-item" @onclick='() => NavigateToPath("/drivers")'>
                                        <i class="bi bi-cpu tree-icon"></i>
                                        <span class="tree-text">Drivers</span>
                                    </div>
                                </div>
                                <div class="tree-node">
                                    <div class="tree-item" @onclick='() => NavigateToPath("/tags")'>
                                        <i class="bi bi-tag tree-icon"></i>
                                        <span class="tree-text">Tags</span>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    };
}

<style>
.project-tree {
    font-size: 12px;
    color: #fafafa;
    user-select: none;
}

.tree-node {
    margin-left: 0;
}

.tree-children {
    margin-left: 16px;
}

.tree-item {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 4px 6px;
    cursor: pointer;
    border-radius: 2px;
    transition: background-color 0.2s;
    min-height: 24px;
}

.tree-item:hover {
    background: rgba(255, 255, 255, 0.1);
}

.tree-item.selected {
    background: rgba(59, 130, 246, 0.3);
    border: 1px solid rgba(59, 130, 246, 0.5);
}

.tree-icon {
    font-size: 14px;
    width: 16px;
    flex-shrink: 0;
}

.tree-text {
    font-size: 12px;
    flex: 1;
}

.device-status {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    margin-left: auto;
}

.device-status.online {
    background: #10b981;
    box-shadow: 0 0 4px #10b981;
}

.project-status {
    width: 12px;
    height: 12px;
    border-radius: 2px;
    margin-left: auto;
    font-size: 8px;
    color: white;
    font-weight: bold;
    text-align: center;
    line-height: 12px;
    flex-shrink: 0;
}

.project-status.active {
    background: #10b981;
}

.project-status.draft {
    background: #3b82f6;
}

.project-status.inactive {
    background: #f59e0b;
}

.project-status.archived {
    background: #6b7280;
}

.root-node .tree-item {
    font-weight: bold;
}
</style>

@code {
    private List<ProjectDto> _projects = new();
    private List<DeviceDto> _devices = new();
    private HashSet<string> _expandedNodes = new();
    private string? _selectedNode;

    protected override async Task OnInitializedAsync()
    {
        await LoadProjects();
        await LoadDevices();
    }

    public async Task RefreshAsync()
    {
        await LoadProjects();
        await LoadDevices();
        StateHasChanged();
    }

    private async Task LoadProjects()
    {
        try
        {
            _projects = (await ProjectApi.GetAllProjectsAsync()).ToList();
            
            // Auto-expand first project if available
            if (_projects.Any() && !_expandedNodes.Any())
            {
                var firstProject = _projects.First();
                _expandedNodes.Add($"project-{firstProject.Id}");
            }
            
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load projects for tree view");
        }
    }

    private async Task LoadDevices()
    {
        try
        {
            // Load devices for all projects
            var allDevices = new List<DeviceDto>();
            foreach (var project in _projects)
            {
                var projectDevices = await DeviceApi.GetDevicesByProjectAsync(project.Id);
                allDevices.AddRange(projectDevices);
            }
            _devices = allDevices;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load devices for tree view");
        }
    }

    private void ToggleNode(string nodeId)
    {
        if (_expandedNodes.Contains(nodeId))
            _expandedNodes.Remove(nodeId);
        else
            _expandedNodes.Add(nodeId);
        StateHasChanged();
    }

    private bool IsExpanded(string nodeId) => _expandedNodes.Contains(nodeId);

    private void SelectDevice(DeviceDto device)
    {
        _selectedNode = $"device-{device.Id}";
        Navigation.NavigateTo($"/device/{device.Id}");
        StateHasChanged();
    }

    private bool IsSelected(string nodeId) => _selectedNode == nodeId;

    private void NavigateToPath(string path)
    {
        Navigation.NavigateTo(path);
    }
}