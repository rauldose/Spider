@using Spider.DeviceManagement.Application.DTOs
@using SpiderStudio.BlazorServer.Services
@inject DeviceManagementApiService DeviceApi
@inject NavigationManager Navigation
@inject ILogger<ProjectTreeComponent> Logger

<div class="project-tree">
    <!-- Project Root -->
    <div class="tree-node root-node">
        <div class="tree-item" @onclick='() => ToggleNode("project")'>>
            <i class="bi @(IsExpanded("project") ? "bi-folder2-open" : "bi-folder2") tree-icon"></i>
            <span class="tree-text">Spider Project</span>
        </div>
        
        @if (IsExpanded("project"))
        {
            <!-- Devices Node -->
            <div class="tree-children">
                <div class="tree-node">
                    <div class="tree-item" @onclick='() => ToggleNode("devices")'>>
                        <i class="bi @(IsExpanded("devices") ? "bi-folder2-open" : "bi-folder2") tree-icon"></i>
                        <span class="tree-text">Devices</span>
                    </div>
                    
                    @if (IsExpanded("devices"))
                    {
                        <div class="tree-children">
                            @foreach (var device in _devices)
                            {
                                <div class="tree-node device-node">
                                    <div class="tree-item @(IsSelected($"device-{device.Id}") ? "selected" : "")" 
                                         @onclick="() => SelectDevice(device)">
                                        <i class="bi bi-cpu tree-icon"></i>
                                        <span class="tree-text">@device.Name</span>
                                        <span class="device-status @(device.Status == "Connected" ? "online" : "offline")"></span>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>

                <!-- APIs Node -->
                <div class="tree-node">
                    <div class="tree-item" @onclick='() => ToggleNode("apis")'>>
                        <i class="bi @(IsExpanded("apis") ? "bi-folder2-open" : "bi-folder2") tree-icon"></i>
                        <span class="tree-text">APIs</span>
                    </div>
                    
                    @if (IsExpanded("apis"))
                    {
                        <div class="tree-children">
                            <div class="tree-node">
                                <div class="tree-item" @onclick='() => NavigateToPath("/devices")'>>
                                    <i class="bi bi-gear tree-icon"></i>
                                    <span class="tree-text">Device Management</span>
                                </div>
                            </div>
                            <div class="tree-node">
                                <div class="tree-item" @onclick='() => NavigateToPath("/drivers")'>>
                                    <i class="bi bi-cpu tree-icon"></i>
                                    <span class="tree-text">Driver Manager</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Links Node -->
                <div class="tree-node">
                    <div class="tree-item" @onclick='() => ToggleNode("links")'>>
                        <i class="bi @(IsExpanded("links") ? "bi-folder2-open" : "bi-folder2") tree-icon"></i>
                        <span class="tree-text">Links</span>
                    </div>
                    
                    @if (IsExpanded("links"))
                    {
                        <div class="tree-children">
                            <div class="tree-node">
                                <div class="tree-item" @onclick='() => NavigateToPath("/connections")'>>
                                    <i class="bi bi-link tree-icon"></i>
                                    <span class="tree-text">Connections</span>
                                </div>
                            </div>
                            <div class="tree-node">
                                <div class="tree-item" @onclick='() => NavigateToPath("/communication")'>>
                                    <i class="bi bi-broadcast tree-icon"></i>
                                    <span class="tree-text">Communication</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

<style>
.project-tree {
    font-size: 12px;
    color: #fafafa;
    user-select: none;
}

.tree-node {
    margin-left: 0;
}

.tree-children {
    margin-left: 16px;
}

.tree-item {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 4px 6px;
    cursor: pointer;
    border-radius: 2px;
    transition: background-color 0.2s;
    min-height: 24px;
}

.tree-item:hover {
    background: rgba(255, 255, 255, 0.1);
}

.tree-item.selected {
    background: rgba(59, 130, 246, 0.3);
    border: 1px solid rgba(59, 130, 246, 0.5);
}

.tree-icon {
    font-size: 14px;
    width: 16px;
    flex-shrink: 0;
}

.tree-text {
    font-size: 12px;
    flex: 1;
}

.device-status {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    margin-left: auto;
}

.device-status.online {
    background: #10b981;
    box-shadow: 0 0 4px #10b981;
}

.device-status.offline {
    background: #6b7280;
}

.root-node .tree-item {
    font-weight: bold;
}
</style>

@code {
    private List<DeviceDto> _devices = new();
    private HashSet<string> _expandedNodes = new() { "project", "devices" };
    private string? _selectedNode;

    protected override async Task OnInitializedAsync()
    {
        await LoadDevices();
    }

    private async Task LoadDevices()
    {
        try
        {
            var projectId = Guid.Parse("00000000-0000-0000-0000-000000000001");
            _devices = (await DeviceApi.GetDevicesByProjectAsync(projectId)).ToList();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load devices for tree view");
        }
    }

    private void ToggleNode(string nodeId)
    {
        if (_expandedNodes.Contains(nodeId))
            _expandedNodes.Remove(nodeId);
        else
            _expandedNodes.Add(nodeId);
        StateHasChanged();
    }

    private bool IsExpanded(string nodeId) => _expandedNodes.Contains(nodeId);

    private void SelectDevice(DeviceDto device)
    {
        _selectedNode = $"device-{device.Id}";
        Navigation.NavigateTo($"/device/{device.Id}");
        StateHasChanged();
    }

    private bool IsSelected(string nodeId) => _selectedNode == nodeId;

    private void NavigateToPath(string path)
    {
        Navigation.NavigateTo(path);
    }
}