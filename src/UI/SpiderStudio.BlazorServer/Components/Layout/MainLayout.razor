@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row">
            <div class="d-flex justify-content-between align-items-center w-100">
                <div>
                    <span class="text-muted small">Industrial IoT Platform</span>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <span class="badge bg-success" title="System Status">
                        <i class="bi bi-circle-fill me-1"></i>Online
                    </span>
                    <a href="https://github.com/rauldose/Spider" target="_blank" class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-github me-1"></i>Documentation
                    </a>
                </div>
            </div>
        </div>

        <article class="content">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    <span class="me-3">An unhandled error has occurred.</span>
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
