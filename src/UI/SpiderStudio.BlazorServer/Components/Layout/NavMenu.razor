<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">🕷️ Spider Studio</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Dashboard
            </NavLink>
        </div>

        <!-- Project Explorer Collapsible Section -->
        <div class="nav-item px-3 mt-3">
            <div class="nav-section-header d-flex align-items-center justify-content-between mb-2">
                <span class="text-muted small fw-bold text-uppercase">Project Explorer</span>
                <button class="btn btn-sm btn-outline-light" @onclick="ToggleProjectTree" title="Toggle Project Tree">
                    <i class="bi @(_showProjectTree ? "bi-chevron-up" : "bi-chevron-down")"></i>
                </button>
            </div>
            @if (_showProjectTree)
            {
                <div class="project-tree-container">
                    <ProjectTreeComponent />
                </div>
            }
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="drivers">
                <span class="bi bi-gear-fill" aria-hidden="true"></span> Drivers
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="devices">
                <span class="bi bi-device-hdd" aria-hidden="true"></span> Device Management
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="connections">
                <span class="bi bi-link-45deg" aria-hidden="true"></span> Connection Management
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="projects">
                <span class="bi bi-folder2" aria-hidden="true"></span> Project Management
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="communication">
                <span class="bi bi-broadcast" aria-hidden="true"></span> Communication
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="tags">
                <span class="bi bi-tags-fill" aria-hidden="true"></span> Tags
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="monitoring">
                <span class="bi bi-activity" aria-hidden="true"></span> Monitoring
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="settings">
                <span class="bi bi-sliders" aria-hidden="true"></span> Settings
            </NavLink>
        </div>
    </nav>
</div>

@code {
    private bool _showProjectTree = true;

    private void ToggleProjectTree()
    {
        _showProjectTree = !_showProjectTree;
        StateHasChanged();
    }
}
