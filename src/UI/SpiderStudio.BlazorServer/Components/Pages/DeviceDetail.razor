@page "/device/{deviceId:guid}"
@using Spider.DeviceManagement.Application.DTOs
@using SpiderStudio.BlazorServer.Services
@inject DeviceManagementApiService DeviceApi
@inject NavigationManager Navigation

<PageTitle>Device - @(_device?.Name ?? "Loading...")</PageTitle>

<!-- WPF-like Device Detail Interface -->
<div class="device-detail-container">
    @if (_device != null)
    {
        <!-- Device Configuration Tabs -->
        <div class="device-tabs">
            <div class="tab-header">
                <button class="tab-button @(_activeTab == "communication" ? "active" : "")" 
                        @onclick='() => SetActiveTab("communication")'>>
                    Communication
                </button>
                <button class="tab-button @(_activeTab == "tags" ? "active" : "")" 
                        @onclick='() => SetActiveTab("tags")'>>
                    Tags
                </button>
            </div>

            <div class="tab-content">
                @if (_activeTab == "communication")
                {
                    <div class="communication-panel">
                        <div class="config-row">
                            <label class="config-label">Protocol:</label>
                            <select class="config-input" @bind="_device.Protocol">
                                <option value="Modbus">Modbus TCP</option>
                                <option value="OpcUa">OPC UA</option>
                                <option value="Mqtt">MQTT</option>
                                <option value="Siemens">Siemens S7</option>
                                <option value="Omron">Omron FINS</option>
                            </select>
                        </div>
                        
                        <div class="config-row">
                            <label class="config-label">Connection String:</label>
                            <input type="text" class="config-input" @bind="_device.ConnectionString" 
                                   placeholder="e.g., 192.168.1.10:502" />
                        </div>
                        
                        <div class="config-row">
                            <label class="config-label">Timeout (ms):</label>
                            <input type="number" class="config-input" value="5000" />
                        </div>

                        <div class="config-actions">
                            <button class="action-btn primary" @onclick="TestConnection">
                                <i class="bi bi-play-circle"></i> Test Connection
                            </button>
                            <button class="action-btn secondary" @onclick="SaveDevice">
                                <i class="bi bi-floppy"></i> Save
                            </button>
                        </div>
                    </div>
                }
                else if (_activeTab == "tags")
                {
                    <div class="tags-panel">
                        <div class="tags-toolbar">
                            <button class="tool-btn" @onclick="AddTag">
                                <i class="bi bi-plus"></i> Add
                            </button>
                            <button class="tool-btn" @onclick="RemoveTag">
                                <i class="bi bi-dash"></i> Remove
                            </button>
                            <button class="tool-btn" @onclick="ImportTags">
                                <i class="bi bi-download"></i> Import
                            </button>
                            <button class="tool-btn" @onclick="ExportTags">
                                <i class="bi bi-upload"></i> Export
                            </button>
                        </div>

                        <div class="tags-grid">
                            <div class="grid-header">
                                <div class="grid-cell">Name</div>
                                <div class="grid-cell">Type</div>
                                <div class="grid-cell">Address</div>
                                <div class="grid-cell">Value</div>
                                <div class="grid-cell">Quality</div>
                            </div>
                            @foreach (var tag in _tags)
                            {
                                <div class="grid-row">
                                    <div class="grid-cell">@tag.Name</div>
                                    <div class="grid-cell">@tag.DataType</div>
                                    <div class="grid-cell">@tag.Address</div>
                                    <div class="grid-cell">@tag.Value</div>
                                    <div class="grid-cell">
                                        <span class="quality-indicator @tag.Quality.ToLower()">@tag.Quality</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    }
    else
    {
        <div class="loading-panel">
            <div class="spinner-border" role="status"></div>
            <span class="ms-2">Loading device...</span>
        </div>
    }
</div>

<style>
.device-detail-container {
    height: 100%;
    background: rgba(229, 229, 229, 0.06);
    display: flex;
    flex-direction: column;
}

/* Device Tabs */
.device-tabs {
    flex: 1;
    display: flex;
    flex-direction: column;
}

.tab-header {
    display: flex;
    border-bottom: 1px solid #555;
    background: rgba(0, 0, 0, 0.2);
}

.tab-button {
    padding: 8px 20px;
    background: transparent;
    border: none;
    color: #fafafa;
    cursor: pointer;
    font-size: 12px;
    border-bottom: 2px solid transparent;
    transition: all 0.2s;
}

.tab-button:hover {
    background: rgba(255, 255, 255, 0.1);
}

.tab-button.active {
    background: rgba(255, 255, 255, 0.1);
    border-bottom-color: #3b82f6;
}

.tab-content {
    flex: 1;
    padding: 20px;
    overflow-y: auto;
}

/* Communication Panel */
.communication-panel {
    max-width: 600px;
}

.config-row {
    display: flex;
    align-items: center;
    margin-bottom: 16px;
    gap: 12px;
}

.config-label {
    width: 120px;
    font-size: 12px;
    color: #fafafa;
    font-weight: bold;
}

.config-input {
    flex: 1;
    padding: 6px 10px;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid #555;
    border-radius: 3px;
    color: #fafafa;
    font-size: 12px;
}

.config-input:focus {
    outline: none;
    border-color: #3b82f6;
    background: rgba(255, 255, 255, 0.15);
}

.config-actions {
    margin-top: 20px;
    display: flex;
    gap: 10px;
}

/* Tags Panel */
.tags-panel {
    height: 100%;
    display: flex;
    flex-direction: column;
}

.tags-toolbar {
    display: flex;
    gap: 8px;
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid #555;
}

.tool-btn {
    padding: 4px 12px;
    background: transparent;
    border: 1px solid #555;
    color: #fafafa;
    font-size: 11px;
    cursor: pointer;
    border-radius: 3px;
    transition: all 0.2s;
}

.tool-btn:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: #3b82f6;
}

.tags-grid {
    flex: 1;
    background: rgba(0, 0, 0, 0.2);
    border: 1px solid #555;
    border-radius: 3px;
    overflow: hidden;
}

.grid-header {
    display: grid;
    grid-template-columns: 1fr 80px 120px 80px 80px;
    background: rgba(0, 0, 0, 0.4);
    border-bottom: 1px solid #555;
}

.grid-row {
    display: grid;
    grid-template-columns: 1fr 80px 120px 80px 80px;
    border-bottom: 1px solid #333;
}

.grid-row:hover {
    background: rgba(255, 255, 255, 0.05);
}

.grid-cell {
    padding: 6px 8px;
    font-size: 11px;
    color: #fafafa;
    border-right: 1px solid #333;
    display: flex;
    align-items: center;
}

.grid-header .grid-cell {
    font-weight: bold;
    text-transform: uppercase;
    background: rgba(0, 0, 0, 0.3);
}

.quality-indicator {
    padding: 2px 6px;
    border-radius: 2px;
    font-size: 10px;
}

.quality-indicator.good {
    background: #10b981;
    color: white;
}

.quality-indicator.bad {
    background: #dc2626;
    color: white;
}

.quality-indicator.uncertain {
    background: #f59e0b;
    color: white;
}

/* Loading Panel */
.loading-panel {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fafafa;
}

/* Action Buttons */
.action-btn {
    padding: 8px 16px;
    border: none;
    border-radius: 3px;
    font-size: 12px;
    font-weight: bold;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 6px;
    transition: all 0.2s;
}

.action-btn.primary {
    background: #3b82f6;
    color: white;
}

.action-btn.primary:hover {
    background: #2563eb;
}

.action-btn.secondary {
    background: rgba(255, 255, 255, 0.1);
    color: #fafafa;
    border: 1px solid #555;
}

.action-btn.secondary:hover {
    background: rgba(255, 255, 255, 0.2);
}
</style>

