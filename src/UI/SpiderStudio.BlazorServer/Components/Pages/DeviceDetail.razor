@page "/devices/{DeviceId}"
@using Spider.DeviceManagement.Application.Commands
@using Spider.DeviceManagement.Application.DTOs
@using Spider.DataAcquisition.Application.DTOs
@using SpiderStudio.BlazorServer.Services
@inject DeviceManagementApiService DeviceApi
@inject DataAcquisitionApiService DataApi
@inject CommunicationApiService CommApi
@inject NavigationManager Navigation
@inject ILogger<DeviceDetail> Logger

<PageTitle>Device Details - @(_device?.Name ?? "Loading") - Spider Studio</PageTitle>

<div class="container-fluid">
    @if (_loading)
    {
        <div class="d-flex justify-content-center align-items-center" style="height: 400px;">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (_device == null)
    {
        <div class="alert alert-danger">
            <h4>Device Not Found</h4>
            <p>The requested device could not be found.</p>
            <button class="btn btn-primary" @onclick="NavigateBack">
                <i class="bi bi-arrow-left me-2"></i>Back to Devices
            </button>
        </div>
    }
    else
    {
        <!-- Header -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb">
                                <li class="breadcrumb-item">
                                    <a href="/devices" class="text-decoration-none">Device Management</a>
                                </li>
                                <li class="breadcrumb-item active">@_device.Name</li>
                            </ol>
                        </nav>
                        <h1 class="h3">🔧 @_device.Name</h1>
                        <p class="text-muted">@_device.Description</p>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-secondary" @onclick="RefreshDevice">
                            <i class="bi bi-arrow-clockwise me-2"></i>Refresh
                        </button>
                        <button class="btn btn-success" @onclick="SaveChanges" disabled="@_isSaving">
                            @if (_isSaving)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                            }
                            else
                            {
                                <i class="bi bi-floppy me-2"></i>
                            }
                            Save Changes
                        </button>
                        <button class="btn btn-outline-danger" @onclick="NavigateBack">
                            <i class="bi bi-x-circle me-2"></i>Close
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Device Status Card -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-3">
                                <div class="d-flex align-items-center">
                                    <div class="status-indicator me-3">
                                        <i class="bi @(_device.IsEnabled ? "bi-check-circle text-success" : "bi-x-circle text-danger") fs-4"></i>
                                    </div>
                                    <div>
                                        <h6 class="mb-0">Status</h6>
                                        <small class="text-muted">@(_device.IsEnabled ? "Enabled" : "Disabled")</small>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div>
                                    <h6 class="mb-0">Protocol</h6>
                                    <small class="text-muted">@_device.Protocol</small>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div>
                                    <h6 class="mb-0">Last Activity</h6>
                                    <small class="text-muted">@(_device.LastConnectedAt?.ToString("yyyy-MM-dd HH:mm:ss") ?? "Never")</small>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div>
                                    <h6 class="mb-0">Data Points</h6>
                                    <small class="text-muted">@_dataPoints.Count items</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tabbed Interface -->
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header p-0">
                        <ul class="nav nav-tabs card-header-tabs" role="tablist">
                            <li class="nav-item">
                                <button class="nav-link @(_activeTab == "communication" ? "active" : "")" 
                                        @onclick="@(() => SetActiveTab("communication"))" 
                                        type="button">
                                    <i class="bi bi-wifi me-2"></i>Communication
                                </button>
                            </li>
                            <li class="nav-item">
                                <button class="nav-link @(_activeTab == "tags" ? "active" : "")" 
                                        @onclick="@(() => SetActiveTab("tags"))" 
                                        type="button">
                                    <i class="bi bi-tags me-2"></i>Data Points
                                </button>
                            </li>
                            <li class="nav-item">
                                <button class="nav-link @(_activeTab == "monitoring" ? "active" : "")" 
                                        @onclick="@(() => SetActiveTab("monitoring"))" 
                                        type="button">
                                    <i class="bi bi-graph-up me-2"></i>Monitoring
                                </button>
                            </li>
                        </ul>
                    </div>
                    <div class="card-body p-4">
                        @if (_activeTab == "communication")
                        {
                            <CommunicationTabComponent Device="_device" OnDeviceChanged="OnDeviceChanged" />
                        }
                        else if (_activeTab == "tags")
                        {
                            <TagsTabComponent DeviceId="_device.Id" DataPoints="_dataPoints" OnDataPointsChanged="OnDataPointsChanged" />
                        }
                        else if (_activeTab == "monitoring")
                        {
                            <MonitoringTabComponent Device="_device" DataPoints="_dataPoints" />
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public string DeviceId { get; set; } = string.Empty;

    private DeviceDto? _device;
    private List<DataPointDto> _dataPoints = new();
    private bool _loading = true;
    private bool _isSaving = false;
    private string _activeTab = "communication";

    protected override async Task OnInitializedAsync()
    {
        await LoadDevice();
    }

    private async Task LoadDevice()
    {
        try
        {
            _loading = true;
            StateHasChanged();

            if (Guid.TryParse(DeviceId, out var deviceGuid))
            {
                _device = await DeviceApi.GetDeviceByIdAsync(deviceGuid);
                if (_device != null)
                {
                    await LoadDataPoints();
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading device {DeviceId}", DeviceId);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task LoadDataPoints()
    {
        try
        {
            if (_device != null)
            {
                var response = await DataApi.GetDataPointsByDeviceAsync(_device.Id);
                _dataPoints = response?.ToList() ?? new List<DataPointDto>();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading data points for device {DeviceId}", DeviceId);
        }
    }

    private async Task RefreshDevice()
    {
        await LoadDevice();
    }

    private async Task SaveChanges()
    {
        try
        {
            _isSaving = true;
            StateHasChanged();

            if (_device != null)
            {
                // Update device if needed
                // await DeviceApi.UpdateDeviceAsync(_device.Id, updateCommand);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving device changes");
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

    private void SetActiveTab(string tab)
    {
        _activeTab = tab;
        StateHasChanged();
    }

    private void OnDeviceChanged(DeviceDto updatedDevice)
    {
        _device = updatedDevice;
        StateHasChanged();
    }

    private void OnDataPointsChanged(List<DataPointDto> updatedDataPoints)
    {
        _dataPoints = updatedDataPoints;
        StateHasChanged();
    }

    private void NavigateBack()
    {
        Navigation.NavigateTo("/devices");
    }
}