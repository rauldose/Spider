    private async Task LoadDevice()
    {
        try
        {
            _device = await DeviceApi.GetDeviceByIdAsync(DeviceId);
            LoadSampleTags();
        }
        catch
        {
            // Handle error - device not found
            Navigation.NavigateTo("/");
        }
    }

    private void LoadSampleTags()
    {
        _tags = new List<TagData>
        {
            new("Temperature", "Float", "40001", "23.5", "Good"),
            new("Pressure", "Int16", "40002", "1250", "Good"),
            new("FlowRate", "Float", "40003", "45.2", "Good"),
            new("Status", "Bool", "00001", "true", "Good"),
            new("Alarm", "Bool", "00002", "false", "Good")
        };
    }

    private void SetActiveTab(string tab)
    {
        _activeTab = tab;
        StateHasChanged();
    }

