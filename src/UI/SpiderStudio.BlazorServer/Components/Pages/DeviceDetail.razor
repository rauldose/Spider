@page "/device/{deviceId:guid}"
@using Spider.DeviceManagement.Application.DTOs
@using SpiderStudio.BlazorServer.Services
@inject DeviceManagementApiService DeviceApi
@inject NavigationManager Navigation

<PageTitle>Device - @(_device?.Name ?? "Loading...")</PageTitle>

<!-- WPF-like Device Detail Interface -->
<div class="device-detail-container">
    @if (_device != null)
    {
        <!-- Device Configuration Tabs -->
        <div class="device-tabs">
            <div class="tab-header">
                <button class="tab-button @(_activeTab == "communication" ? "active" : "")" 
                        @onclick='() => SetActiveTab("communication")'>>
                    Communication
                </button>
                <button class="tab-button @(_activeTab == "tags" ? "active" : "")" 
                        @onclick='() => SetActiveTab("tags")'>>
                    Tags
                </button>
            </div>

            <div class="tab-content">
                @if (_activeTab == "communication")
                {
                    <div class="communication-panel">
                        <div class="config-row">
                            <label class="config-label">Protocol:</label>
                            <select class="config-input" @bind="_device.Protocol">
                                @foreach (var protocol in _availableProtocols)
                                {
                                    <option value="@protocol">@protocol</option>
                                }
                            </select>
                        </div>

                        <div class="config-row">
                            <label class="config-label">Transport:</label>
                            <select class="config-input" @bind="_selectedTransport">
                                @foreach (var transport in _availableTransports)
                                {
                                    <option value="@transport">@transport</option>
                                }
                            </select>
                        </div>
                        
                        <div class="config-row">
                            <label class="config-label">Connection String:</label>
                            <input type="text" class="config-input" @bind="_device.ConnectionString" 
                                   placeholder="e.g., 192.168.1.10:502" />
                        </div>
                        
                        <div class="config-row">
                            <label class="config-label">Timeout (ms):</label>
                            <input type="number" class="config-input" value="5000" />
                        </div>

                        <div class="config-row">
                            <label class="config-label">Status:</label>
                            <span class="status-indicator @(_connectionStatus.Contains("Connected") ? "connected" : _connectionStatus.Contains("Error") ? "error" : "disconnected")">
                                @_connectionStatus
                            </span>
                        </div>

                        <div class="config-actions">
                            <button class="action-btn primary" @onclick="TestConnection" disabled="@_isConnecting">
                                <i class="bi @(_isConnecting ? "bi-arrow-clockwise spinning" : "bi-play-circle")"></i> 
                                @(_isConnecting ? "Testing..." : "Test Connection")
                            </button>
                            <button class="action-btn secondary" @onclick="SaveDevice">
                                <i class="bi bi-floppy"></i> Save
                            </button>
                        </div>
                    </div>
                }
                else if (_activeTab == "tags")
                {
                    <div class="tags-panel">
                        <div class="tags-toolbar">
                            <button class="tool-btn" @onclick="AddTag">
                                <i class="bi bi-plus"></i> Add
                            </button>
                            <button class="tool-btn" @onclick="RemoveTag">
                                <i class="bi bi-dash"></i> Remove
                            </button>
                            <button class="tool-btn" @onclick="ImportTags">
                                <i class="bi bi-download"></i> Import
                            </button>
                            <button class="tool-btn" @onclick="ExportTags">
                                <i class="bi bi-upload"></i> Export
                            </button>
                        </div>

                        <div class="tags-grid">
                            <div class="grid-header">
                                <div class="grid-cell">Name</div>
                                <div class="grid-cell">Type</div>
                                <div class="grid-cell">Address</div>
                                <div class="grid-cell">Value</div>
                                <div class="grid-cell">Quality</div>
                                <div class="grid-cell">Actions</div>
                            </div>
                            @foreach (var tag in _tags)
                            {
                                <div class="grid-row">
                                    <div class="grid-cell">@tag.Name</div>
                                    <div class="grid-cell">@tag.DataType</div>
                                    <div class="grid-cell">@tag.Address</div>
                                    <div class="grid-cell">@tag.Value</div>
                                    <div class="grid-cell">
                                        <span class="quality-indicator @tag.Quality.ToLower()">@tag.Quality</span>
                                    </div>
                                    <div class="grid-cell">
                                        <button class="mini-btn" @onclick="() => EditTag(tag)" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="mini-btn" @onclick="() => TestModbusRead(tag)" title="Test Read">
                                            <i class="bi bi-play-fill"></i>
                                        </button>
                                        <button class="mini-btn danger" @onclick="() => RemoveTag(tag)" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>

                        @if (_tags.Count == 0)
                        {
                            <div class="empty-state">
                                <p>No tags configured. Click Add to create your first tag.</p>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }
    else
    {
        <div class="loading-panel">
            <div class="spinner-border" role="status"></div>
            <span class="ms-2">Loading device...</span>
        </div>
    }
</div>

<!-- Add/Edit Tag Modal -->
@if (_showAddTagModal)
{
    <div class="modal-overlay" @onclick="() => _showAddTagModal = false">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h4>@(_editingTag == null ? "Add New Tag" : "Edit Tag")</h4>
                <button class="close-btn" @onclick="() => _showAddTagModal = false">
                    <i class="bi bi-x"></i>
                </button>
            </div>
            <div class="modal-body">
                <div class="form-row">
                    <label>Name:</label>
                    <input type="text" @bind="_newTagName" placeholder="Enter tag name" />
                </div>
                <div class="form-row">
                    <label>Data Type:</label>
                    <select @bind="_newTagType">
                        <option value="Bool">Boolean</option>
                        <option value="Int16">Int16</option>
                        <option value="Int32">Int32</option>
                        <option value="Float">Float</option>
                        <option value="String">String</option>
                    </select>
                </div>
                <div class="form-row">
                    <label>Address:</label>
                    <input type="text" @bind="_newTagAddress" placeholder="e.g., 40001" />
                </div>
            </div>
            <div class="modal-footer">
                <button class="modal-btn primary" @onclick="SaveTag">
                    <i class="bi bi-check"></i> Save
                </button>
                <button class="modal-btn secondary" @onclick="() => _showAddTagModal = false">
                    <i class="bi bi-x"></i> Cancel
                </button>
            </div>
        </div>
    </div>
}

<style>
.device-detail-container {
    height: 100%;
    background: rgba(229, 229, 229, 0.06);
    display: flex;
    flex-direction: column;
}

/* Device Tabs */
.device-tabs {
    flex: 1;
    display: flex;
    flex-direction: column;
}

.tab-header {
    display: flex;
    border-bottom: 1px solid #555;
    background: rgba(0, 0, 0, 0.2);
}

.tab-button {
    padding: 8px 20px;
    background: transparent;
    border: none;
    color: #fafafa;
    cursor: pointer;
    font-size: 12px;
    border-bottom: 2px solid transparent;
    transition: all 0.2s;
}

.tab-button:hover {
    background: rgba(255, 255, 255, 0.1);
}

.tab-button.active {
    background: rgba(255, 255, 255, 0.1);
    border-bottom-color: #3b82f6;
}

.tab-content {
    flex: 1;
    padding: 20px;
    overflow-y: auto;
}

/* Communication Panel */
.communication-panel {
    max-width: 600px;
}

.config-row {
    display: flex;
    align-items: center;
    margin-bottom: 16px;
    gap: 12px;
}

.config-label {
    width: 120px;
    font-size: 12px;
    color: #fafafa;
    font-weight: bold;
}

.config-input {
    flex: 1;
    padding: 6px 10px;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid #555;
    border-radius: 3px;
    color: #fafafa;
    font-size: 12px;
}

.config-input:focus {
    outline: none;
    border-color: #3b82f6;
    background: rgba(255, 255, 255, 0.15);
}

.config-actions {
    margin-top: 20px;
    display: flex;
    gap: 10px;
}

/* Tags Panel */
.tags-panel {
    height: 100%;
    display: flex;
    flex-direction: column;
}

.tags-toolbar {
    display: flex;
    gap: 8px;
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid #555;
}

.tool-btn {
    padding: 4px 12px;
    background: transparent;
    border: 1px solid #555;
    color: #fafafa;
    font-size: 11px;
    cursor: pointer;
    border-radius: 3px;
    transition: all 0.2s;
}

.tool-btn:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: #3b82f6;
}

.tags-grid {
    flex: 1;
    background: rgba(0, 0, 0, 0.2);
    border: 1px solid #555;
    border-radius: 3px;
    overflow: hidden;
}

.grid-header {
    display: grid;
    grid-template-columns: 1fr 80px 120px 80px 80px 120px;
    background: rgba(0, 0, 0, 0.4);
    border-bottom: 1px solid #555;
}

.grid-row {
    display: grid;
    grid-template-columns: 1fr 80px 120px 80px 80px 120px;
    border-bottom: 1px solid #333;
}

.grid-row:hover {
    background: rgba(255, 255, 255, 0.05);
}

.grid-cell {
    padding: 6px 8px;
    font-size: 11px;
    color: #fafafa;
    border-right: 1px solid #333;
    display: flex;
    align-items: center;
}

.grid-header .grid-cell {
    font-weight: bold;
    text-transform: uppercase;
    background: rgba(0, 0, 0, 0.3);
}

.quality-indicator {
    padding: 2px 6px;
    border-radius: 2px;
    font-size: 10px;
}

.quality-indicator.good {
    background: #10b981;
    color: white;
}

.quality-indicator.bad {
    background: #dc2626;
    color: white;
}

.quality-indicator.uncertain {
    background: #f59e0b;
    color: white;
}

/* Loading Panel */
.loading-panel {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fafafa;
}

/* Action Buttons */
.action-btn {
    padding: 8px 16px;
    border: none;
    border-radius: 3px;
    font-size: 12px;
    font-weight: bold;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 6px;
    transition: all 0.2s;
}

.action-btn.primary {
    background: #3b82f6;
    color: white;
}

.action-btn.primary:hover {
    background: #2563eb;
}

.action-btn.secondary {
    background: rgba(255, 255, 255, 0.1);
    color: #fafafa;
    border: 1px solid #555;
}

.action-btn.secondary:hover {
    background: rgba(255, 255, 255, 0.2);
}

/* Status Indicator */
.status-indicator {
    padding: 4px 8px;
    border-radius: 3px;
    font-size: 11px;
    font-weight: bold;
}

.status-indicator.connected {
    background: #10b981;
    color: white;
}

.status-indicator.disconnected {
    background: #6b7280;
    color: white;
}

.status-indicator.error {
    background: #dc2626;
    color: white;
}

/* Spinning animation */
.spinning {
    animation: spin 1s linear infinite;
}

/* Keyframes for spinning animation */
@@keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
}

/* Mini buttons for actions */
.mini-btn {
    padding: 2px 6px;
    margin: 0 2px;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid #555;
    color: #fafafa;
    font-size: 10px;
    cursor: pointer;
    border-radius: 2px;
    transition: all 0.2s;
}

.mini-btn:hover {
    background: rgba(255, 255, 255, 0.2);
    border-color: #3b82f6;
}

.mini-btn.danger:hover {
    background: #dc2626;
    border-color: #dc2626;
}

/* Empty state */
.empty-state {
    text-align: center;
    padding: 40px 20px;
    color: #9ca3af;
    font-style: italic;
}

/* Modal styles */
.modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
}

.modal-content {
    background: #2d3748;
    border-radius: 8px;
    border: 1px solid #555;
    min-width: 400px;
    max-width: 600px;
    color: #fafafa;
}

.modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 20px;
    border-bottom: 1px solid #555;
}

.modal-header h4 {
    margin: 0;
    font-size: 16px;
}

.close-btn {
    background: none;
    border: none;
    color: #fafafa;
    font-size: 20px;
    cursor: pointer;
    padding: 4px;
    border-radius: 3px;
}

.close-btn:hover {
    background: rgba(255, 255, 255, 0.1);
}

.modal-body {
    padding: 20px;
}

.form-row {
    margin-bottom: 16px;
}

.form-row label {
    display: block;
    margin-bottom: 4px;
    font-size: 12px;
    font-weight: bold;
    color: #fafafa;
}

.form-row input, .form-row select {
    width: 100%;
    padding: 8px 12px;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid #555;
    border-radius: 3px;
    color: #fafafa;
    font-size: 12px;
}

.form-row input:focus, .form-row select:focus {
    outline: none;
    border-color: #3b82f6;
    background: rgba(255, 255, 255, 0.15);
}

.modal-footer {
    display: flex;
    gap: 10px;
    justify-content: flex-end;
    padding: 16px 20px;
    border-top: 1px solid #555;
}

.modal-btn {
    padding: 8px 16px;
    border: none;
    border-radius: 3px;
    font-size: 12px;
    font-weight: bold;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 6px;
    transition: all 0.2s;
}

.modal-btn.primary {
    background: #3b82f6;
    color: white;
}

.modal-btn.primary:hover {
    background: #2563eb;
}

.modal-btn.secondary {
    background: rgba(255, 255, 255, 0.1);
    color: #fafafa;
    border: 1px solid #555;
}

.modal-btn.secondary:hover {
    background: rgba(255, 255, 255, 0.2);
}
</style>

@code {
    [Parameter] public Guid DeviceId { get; set; }
    
    private DeviceDto? _device;
    private string _activeTab = "communication";
    private List<TagData> _tags = new();
    private List<string> _availableProtocols = new() { "Modbus", "OpcUa", "Mqtt", "Siemens", "Omron" };
    private List<string> _availableTransports = new() { "TCP", "RTU", "ASCII", "UDP" };
    private string _selectedTransport = "TCP";
    private string _connectionStatus = "Disconnected";
    private bool _isConnecting = false;
    private bool _showAddTagModal = false;
    private TagData? _editingTag = null;
    private string _newTagName = "";
    private string _newTagType = "Int16";
    private string _newTagAddress = "";

    [Inject] private DriverManagerService DriverManager { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        await LoadDevice();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_device?.Id != DeviceId)
        {
            await LoadDevice();
        }
    }

    private async Task LoadDevice()
    {
        try
        {
            _device = await DeviceApi.GetDeviceByIdAsync(DeviceId);
            if (_device != null)
            {
                await LoadDeviceTags();
            }
            else
            {
                // Device not found, create a sample device
                _device = new DeviceDto
                {
                    Id = DeviceId,
                    Name = "Sample Device",
                    Protocol = "Modbus",
                    ConnectionString = "192.168.1.100:502",
                    IsEnabled = true,
                    Status = "Disconnected",
                    ProjectId = Guid.Parse("00000000-0000-0000-0000-000000000001")
                };
                LoadSampleTags();
            }
        }
        catch (Exception ex)
        {
            // Handle error - API not available, create a sample device
            _device = new DeviceDto
            {
                Id = DeviceId,
                Name = "Sample Device (Offline)",
                Protocol = "Modbus",
                ConnectionString = "192.168.1.100:502",
                IsEnabled = true,
                Status = "Disconnected",
                ProjectId = Guid.Parse("00000000-0000-0000-0000-000000000001")
            };
            LoadSampleTags();
        }
        finally
        {
            StateHasChanged();
        }
    }

    private async Task LoadDeviceTags()
    {
        // Load tags from device configuration
        LoadSampleTags(); // For now, use sample data
    }

    private void LoadSampleTags()
    {
        _tags = new List<TagData>
        {
            new("Temperature", "Float", "40001", "23.5", "Good"),
            new("Pressure", "Int16", "40002", "1250", "Good"),
            new("FlowRate", "Float", "40003", "45.2", "Good"),
            new("Status", "Bool", "00001", "true", "Good"),
            new("Alarm", "Bool", "00002", "false", "Good")
        };
    }

    private void SetActiveTab(string tab)
    {
        _activeTab = tab;
        StateHasChanged();
    }

    private async Task TestConnection()
    {
        if (_device == null || _isConnecting) return;

        _isConnecting = true;
        _connectionStatus = "Connecting...";
        StateHasChanged();

        try
        {
            // Create driver configuration
            var parameters = new Dictionary<string, object>
            {
                { "Transport", _selectedTransport },
                { "Timeout", 5000 },
                { "Retries", 3 }
            };

            var config = new Spider.Drivers.Core.Models.DriverConfiguration(
                BuildConnectionString(),
                parameters,
                TimeSpan.FromSeconds(30),
                TimeSpan.FromSeconds(10),
                3,
                true);

            // Create driver instance
            var driver = await DriverManager.CreateDriverAsync(_device.Protocol);
            
            // Initialize driver
            var result = await driver.InitializeAsync(config, CancellationToken.None);
            
            if (result.Success)
            {
                // Test health
                var healthResult = await driver.HealthCheckAsync(CancellationToken.None);
                _connectionStatus = healthResult.IsHealthy ? "Connected" : $"Error: {healthResult.ErrorMessage}";
                
                // Register driver for later use
                await DriverManager.RegisterDriverInstanceAsync(_device.Name, driver);
            }
            else
            {
                _connectionStatus = $"Failed: {result.ErrorMessage}";
            }
        }
        catch (Exception ex)
        {
            _connectionStatus = $"Error: {ex.Message}";
        }
        finally
        {
            _isConnecting = false;
            StateHasChanged();
        }
    }

    private string BuildConnectionString()
    {
        if (_device == null) return "";
        
        return _selectedTransport.ToLower() switch
        {
            "tcp" => _device.ConnectionString,
            "rtu" => $"COM1;9600;8;None;1", // Example serial config
            "ascii" => $"COM1;9600;8;None;1", 
            "udp" => _device.ConnectionString.Replace(":502", ":502"),
            _ => _device.ConnectionString
        };
    }

    private async Task SaveDevice()
    {
        if (_device == null) return;

        try
        {
            // Update connection string with transport
            _device.ConnectionString = BuildConnectionString();
            
            // In a real implementation, would save to API
            _connectionStatus = "Configuration Saved";
            StateHasChanged();
            
            await Task.Delay(2000);
            _connectionStatus = "Disconnected";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _connectionStatus = $"Save Error: {ex.Message}";
            StateHasChanged();
        }
    }

    private void AddTag()
    {
        _editingTag = null;
        _newTagName = "";
        _newTagType = "Int16";
        _newTagAddress = "";
        _showAddTagModal = true;
        StateHasChanged();
    }

    private void EditTag(TagData tag)
    {
        _editingTag = tag;
        _newTagName = tag.Name;
        _newTagType = tag.DataType;
        _newTagAddress = tag.Address;
        _showAddTagModal = true;
        StateHasChanged();
    }

    private void SaveTag()
    {
        if (string.IsNullOrWhiteSpace(_newTagName) || string.IsNullOrWhiteSpace(_newTagAddress))
            return;

        if (_editingTag != null)
        {
            // Edit existing tag
            var index = _tags.IndexOf(_editingTag);
            if (index >= 0)
            {
                _tags[index] = new TagData(_newTagName, _newTagType, _newTagAddress, _editingTag.Value, _editingTag.Quality);
            }
        }
        else
        {
            // Add new tag
            _tags.Add(new TagData(_newTagName, _newTagType, _newTagAddress, "0", "Good"));
        }

        _showAddTagModal = false;
        StateHasChanged();
    }

    private void RemoveTag()
    {
        // Remove selected tags (simplified - in real implementation would track selections)
        if (_tags.Any())
        {
            _tags.RemoveAt(_tags.Count - 1);
            StateHasChanged();
        }
    }

    private void RemoveTag(TagData tag)
    {
        _tags.Remove(tag);
        StateHasChanged();
    }

    private async Task ImportTags()
    {
        // For demo, add some imported tags
        var importedTags = new List<TagData>
        {
            new("ImportedTemp1", "Float", "40010", "25.3", "Good"),
            new("ImportedTemp2", "Float", "40011", "26.1", "Good"),
            new("ImportedPressure", "Int32", "40012", "1300", "Good")
        };

        _tags.AddRange(importedTags);
        StateHasChanged();
    }

    private async Task ExportTags()
    {
        // For demo, simulate export by showing status
        _connectionStatus = "Tags Exported to tags.csv";
        StateHasChanged();
        
        await Task.Delay(2000);
        _connectionStatus = "Disconnected";
        StateHasChanged();
    }

    private async Task TestModbusRead(TagData tag)
    {
        try
        {
            var driver = DriverManager.GetDriverByName(_device?.Name ?? "");
            if (driver is Spider.Drivers.Core.Abstractions.IReadableDriver readableDriver)
            {
                var request = new Spider.Drivers.Core.Models.ReadRequest(tag.Address, tag.DataType);
                var result = await readableDriver.ReadAsync(request);
                
                if (result.Success)
                {
                    // Update tag value
                    var index = _tags.IndexOf(tag);
                    if (index >= 0)
                    {
                        _tags[index] = tag with { Value = result.Value?.ToString() ?? "null", Quality = result.DataQuality };
                        StateHasChanged();
                    }
                }
            }
        }
        catch (Exception ex)
        {
            // Handle error
            var index = _tags.IndexOf(tag);
            if (index >= 0)
            {
                _tags[index] = tag with { Quality = "Bad" };
                StateHasChanged();
            }
            // Log the exception if needed
            Console.WriteLine($"Error testing tag read: {ex.Message}");
        }
    }

    public record TagData(string Name, string DataType, string Address, string Value, string Quality);
}