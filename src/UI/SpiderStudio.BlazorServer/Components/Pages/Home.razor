@page "/"
@using Spider.Drivers.Core.Abstractions
@using Spider.Drivers.Core.Models
@using SpiderStudio.BlazorServer.Services
@using Spider.ConnectionManagement.Application.DTOs
@using Spider.ConnectionManagement.Application.Queries
@using Spider.ProjectManagement.Application.DTOs
@using Spider.Communication.Application.DTOs
@inject DriverManagerService DriverManager
@inject DeviceManagementApiService DeviceApi
@inject DataAcquisitionApiService DataApi
@inject ConnectionManagementApiService ConnectionApi
@inject ProjectManagementApiService ProjectApi
@inject CommunicationApiService CommunicationApi
@inject ILogger<Home> Logger

<PageTitle>Spider Studio - Modern IoT Platform</PageTitle>

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="display-4 text-primary">🕷️ Spider Studio</h1>
                    <p class="lead">Modern IoT Device Collection Platform</p>
                </div>
                <div>
                    <button class="btn btn-success me-2" @onclick="ConnectAllDrivers" disabled="@_isConnecting">
                        @if (_isConnecting)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        }
                        Connect All
                    </button>
                    <button class="btn btn-outline-secondary" @onclick="DisconnectAllDrivers">
                        Disconnect All
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modern DDD API Status Dashboard -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">🏗️ Modern DDD Architecture Status</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-2">
                            <div class="card @(_deviceApiHealthy ? "border-success" : "border-danger")">
                                <div class="card-body text-center">
                                    <i class="bi bi-device-hdd" style="font-size: 2rem; color: @(_deviceApiHealthy ? "#28a745" : "#dc3545");"></i>
                                    <h6 class="mt-2">Device Management</h6>
                                    <span class="badge @(_deviceApiHealthy ? "bg-success" : "bg-danger")">
                                        @(_deviceApiHealthy ? "Healthy" : "Unavailable")
                                    </span>
                                    <div class="mt-2">
                                        <small class="text-muted">Devices: <strong>@_deviceCount</strong></small>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="card @(_dataApiHealthy ? "border-success" : "border-danger")">
                                <div class="card-body text-center">
                                    <i class="bi bi-graph-up" style="font-size: 2rem; color: @(_dataApiHealthy ? "#28a745" : "#dc3545");"></i>
                                    <h6 class="mt-2">Data Acquisition</h6>
                                    <span class="badge @(_dataApiHealthy ? "bg-success" : "bg-danger")">
                                        @(_dataApiHealthy ? "Healthy" : "Unavailable")
                                    </span>
                                    <div class="mt-2">
                                        <small class="text-muted">Data Points: <strong>@_dataPointCount</strong></small>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="card @(_connectionApiHealthy ? "border-success" : "border-danger")">
                                <div class="card-body text-center">
                                    <i class="bi bi-link-45deg" style="font-size: 2rem; color: @(_connectionApiHealthy ? "#28a745" : "#dc3545");"></i>
                                    <h6 class="mt-2">Connection Management</h6>
                                    <span class="badge @(_connectionApiHealthy ? "bg-success" : "bg-danger")">
                                        @(_connectionApiHealthy ? "Healthy" : "Unavailable")
                                    </span>
                                    <div class="mt-2">
                                        <small class="text-muted">Connected: <strong>@(_connectionStats?.ConnectedCount ?? 0)</strong>/@(_connectionStats?.TotalConnections ?? 0)</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="card @(_projectApiHealthy ? "border-success" : "border-danger")">
                                <div class="card-body text-center">
                                    <i class="bi bi-folder2" style="font-size: 2rem; color: @(_projectApiHealthy ? "#28a745" : "#dc3545");"></i>
                                    <h6 class="mt-2">Project Management</h6>
                                    <span class="badge @(_projectApiHealthy ? "bg-success" : "bg-danger")">
                                        @(_projectApiHealthy ? "Healthy" : "Unavailable")
                                    </span>
                                    <div class="mt-2">
                                        <small class="text-muted">Active: <strong>@(_projectStats?.ActiveProjects ?? 0)</strong>/@(_projectStats?.TotalProjects ?? 0)</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="card @(_communicationApiHealthy ? "border-success" : "border-danger")">
                                <div class="card-body text-center">
                                    <i class="bi bi-broadcast" style="font-size: 2rem; color: @(_communicationApiHealthy ? "#28a745" : "#dc3545");"></i>
                                    <h6 class="mt-2">Communication</h6>
                                    <span class="badge @(_communicationApiHealthy ? "bg-success" : "bg-danger")">
                                        @(_communicationApiHealthy ? "Healthy" : "Unavailable")
                                    </span>
                                    <div class="mt-2">
                                        <small class="text-muted">Links: <strong>@(_communicationStats?.ConnectedLinks ?? 0)</strong>/@(_communicationStats?.TotalLinks ?? 0)</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    @if (_connectionStats != null && _connectionApiHealthy)
                    {
                        <hr>
                        <div class="row">
                            <div class="col-md-3">
                                <div class="text-center">
                                    <div class="h4 text-success">@_connectionStats.HealthyCount</div>
                                    <small class="text-muted">Healthy Connections</small>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="text-center">
                                    <div class="h4 text-warning">@_connectionStats.UnhealthyCount</div>
                                    <small class="text-muted">Unhealthy</small>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="text-center">
                                    <div class="h4 text-danger">@_connectionStats.FailedCount</div>
                                    <small class="text-muted">Failed</small>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="text-center">
                                    <div class="h4 text-info">@_connectionStats.AverageResponseTime.ToString("F1")ms</div>
                                    <small class="text-muted">Avg Response</small>
                                </div>
                            </div>
                        </div>
                    }
                    
                    <div class="d-flex justify-content-end mt-3">
                        <button class="btn btn-outline-secondary btn-sm" @onclick="RefreshApiStatus">
                            <i class="bi bi-arrow-clockwise me-2"></i>Refresh Status
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Driver Overview</h5>
                </div>
                <div class="card-body">
                    @if (_drivers.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th>Protocol</th>
                                        <th>Status</th>
                                        <th>Capabilities</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var driver in _drivers)
                                    {
                                        <tr>
                                            <td>
                                                <strong>@driver.Metadata.Name</strong><br>
                                                <small class="text-muted">@driver.Metadata.Version</small>
                                            </td>
                                            <td>
                                                <span class="badge bg-info">@string.Join(", ", driver.Metadata.SupportedProtocols)</span>
                                            </td>
                                            <td>
                                                <span class="badge @GetStatusBadgeClass(driver.Status)">
                                                    @driver.Status.Name
                                                </span>
                                            </td>
                                            <td>
                                                <small>@string.Join(", ", GetCapabilityNames(driver.Capabilities))</small>
                                            </td>
                                            <td>
                                                <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => TestDriver(driver)">
                                                    Test
                                                </button>
                                                <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveDriver(driver.Metadata.Name)">
                                                    Remove
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-inbox" style="font-size: 3rem; color: #6c757d;"></i>
                            <h5 class="mt-3 text-muted">No drivers configured</h5>
                            <p class="text-muted">Add drivers to start collecting IoT data</p>
                            <button class="btn btn-primary" @onclick="AddDemoDriver">
                                Add Demo Driver
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">System Status</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-6">
                            <div class="text-center">
                                <div class="h2 text-primary">@_drivers.Count</div>
                                <div class="text-muted">Total Drivers</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="text-center">
                                <div class="h2 text-success">@_connectedCount</div>
                                <div class="text-muted">Connected</div>
                            </div>
                        </div>
                        <div class="col-12">
                            <hr>
                            <h6>Protocol Distribution</h6>
                            @foreach (var protocol in _protocolStats)
                            {
                                <div class="d-flex justify-content-between">
                                    <span>@protocol.Key</span>
                                    <span class="badge bg-secondary">@protocol.Value</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            @if (_testResults.Any())
            {
                <div class="card mt-3">
                    <div class="card-header">
                        <h6 class="card-title mb-0">Recent Test Results</h6>
                    </div>
                    <div class="card-body">
                        @foreach (var result in _testResults.TakeLast(5))
                        {
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <small>@result.Key</small>
                                <span class="badge @(result.Value ? "bg-success" : "bg-danger")">
                                    @(result.Value ? "✓" : "✗")
                                </span>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private List<IDriver> _drivers = new();
    private bool _isConnecting = false;
    private int _connectedCount = 0;
    private Dictionary<string, int> _protocolStats = new();
    private List<KeyValuePair<string, bool>> _testResults = new();
    
    // Modern DDD API status
    private bool _deviceApiHealthy = false;
    private bool _dataApiHealthy = false;
    private bool _connectionApiHealthy = false;
    private bool _projectApiHealthy = false;
    private bool _communicationApiHealthy = false;
    private int _deviceCount = 0;
    private int _dataPointCount = 0;
    private ConnectionStatisticsDto? _connectionStats;
    private ProjectStatisticsDto? _projectStats;
    private CommunicationStatisticsDto? _communicationStats;

    protected override async Task OnInitializedAsync()
    {
        DriverManager.DriversChanged += OnDriversChanged;
        RefreshDriverList();
        await RefreshApiStatus();
    }

    private void OnDriversChanged(object? sender, EventArgs e)
    {
        InvokeAsync(() =>
        {
            RefreshDriverList();
            StateHasChanged();
        });
    }

    private void RefreshDriverList()
    {
        _drivers = DriverManager.GetDrivers().ToList();
        _connectedCount = _drivers.Count(d => d.Status == DriverStatus.Connected);
        
        _protocolStats = _drivers
            .SelectMany(d => d.Metadata.SupportedProtocols, (driver, protocol) => protocol)
            .GroupBy(protocol => protocol)
            .ToDictionary(g => g.Key, g => g.Count());
    }

    private async Task ConnectAllDrivers()
    {
        _isConnecting = true;
        StateHasChanged();

        try
        {
            var results = await DriverManager.ConnectAllAsync();
            Logger.LogInformation("Connected {Count} drivers", results.Count(r => r.Value));
            RefreshDriverList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error connecting drivers");
        }
        finally
        {
            _isConnecting = false;
            StateHasChanged();
        }
    }

    private async Task DisconnectAllDrivers()
    {
        await DriverManager.ShutdownAllAsync();
        RefreshDriverList();
        StateHasChanged();
    }

    private async Task RefreshApiStatus()
    {
        try
        {
            // Check API health
            _deviceApiHealthy = await DeviceApi.CheckHealthAsync();
            _dataApiHealthy = await DataApi.CheckHealthAsync();
            _connectionApiHealthy = await ConnectionApi.CheckHealthAsync();
            _projectApiHealthy = await ProjectApi.IsHealthyAsync();
            _communicationApiHealthy = await CommunicationApi.IsHealthyAsync();

            // Get device count (using demo project ID)
            if (_deviceApiHealthy)
            {
                var projectId = Guid.Parse("00000000-0000-0000-0000-000000000001");
                var devices = await DeviceApi.GetDevicesByProjectAsync(projectId);
                _deviceCount = devices.Count();
            }

            // Get data point count (sum across all devices)
            if (_dataApiHealthy && _deviceCount > 0)
            {
                var projectId = Guid.Parse("00000000-0000-0000-0000-000000000001");
                var devices = await DeviceApi.GetDevicesByProjectAsync(projectId);
                int totalDataPoints = 0;
                foreach (var device in devices)
                {
                    var dataPoints = await DataApi.GetDataPointsByDeviceAsync(device.Id);
                    totalDataPoints += dataPoints.Count();
                }
                _dataPointCount = totalDataPoints;
            }

            // Get connection statistics
            if (_connectionApiHealthy)
            {
                _connectionStats = await ConnectionApi.GetConnectionStatisticsAsync();
            }

            // Get project statistics
            if (_projectApiHealthy)
            {
                _projectStats = await ProjectApi.GetProjectStatisticsAsync();
            }

            // Get communication statistics
            if (_communicationApiHealthy)
            {
                _communicationStats = await CommunicationApi.GetStatisticsAsync();
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error refreshing API status");
        }
    }

    private async Task TestDriver(IDriver driver)
    {
        try
        {
            if (driver is IReadableDriver readableDriver)
            {
                var request = new ReadRequest("40001", "Int16");
                var result = await readableDriver.ReadAsync(request);
                _testResults.Add(new KeyValuePair<string, bool>(driver.Metadata.Name, result.Success));
                
                Logger.LogInformation("Test result for {Driver}: {Result}", driver.Metadata.Name, result.Success);
            }
            else
            {
                _testResults.Add(new KeyValuePair<string, bool>(driver.Metadata.Name, false));
                Logger.LogWarning("Driver {Driver} does not support reading", driver.Metadata.Name);
            }
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error testing driver {Driver}", driver.Metadata.Name);
            _testResults.Add(new KeyValuePair<string, bool>(driver.Metadata.Name, false));
            StateHasChanged();
        }
    }

    private void RemoveDriver(string driverName)
    {
        DriverManager.RemoveDriver(driverName);
    }

    private void AddDemoDriver()
    {
        var demoDriver = new SpiderStudio.BlazorServer.Drivers.DemoModbusDriver(Logger as ILogger<SpiderStudio.BlazorServer.Drivers.DemoModbusDriver>);
        DriverManager.AddDriver(demoDriver);
    }

    private static string GetStatusBadgeClass(DriverStatus status)
    {
        return status.Name switch
        {
            "Connected" => "bg-success",
            "Connecting" or "Initializing" => "bg-warning", 
            "Disconnected" or "Uninitialized" => "bg-secondary",
            "Error" => "bg-danger",
            "Ready" => "bg-info",
            _ => "bg-secondary"
        };
    }

    private static IEnumerable<string> GetCapabilityNames(DriverCapabilities capabilities)
    {
        var names = new List<string>();
        
        if (capabilities.SupportsReading) names.Add("Read");
        if (capabilities.SupportsWriting) names.Add("Write");
        if (capabilities.SupportsSubscriptions) names.Add("Subscribe");
        if (capabilities.SupportsRealTime) names.Add("Real-time");
        
        return names;
    }

    public void Dispose()
    {
        DriverManager.DriversChanged -= OnDriversChanged;
    }
}
