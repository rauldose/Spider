@page "/"
@using Spider.DeviceManagement.Application.DTOs
@using SpiderStudio.BlazorServer.Services
@inject NavigationManager Navigation
@inject DeviceManagementApiService DeviceApi
@inject ProjectManagementApiService ProjectApi
@inject ILogger<Home> Logger

<PageTitle>Spider Studio - Home</PageTitle>

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="display-5">🏠 Spider Studio</h1>
                    <p class="lead">Modern IoT Device Collection Platform</p>
                </div>
                <div>
                    <button class="btn btn-primary me-2" @onclick="ConnectAll">
                        <i class="bi bi-play-circle me-1"></i>Connect All
                    </button>
                    <button class="btn btn-outline-secondary" @onclick="DisconnectAll">
                        <i class="bi bi-stop-circle me-1"></i>Disconnect All
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- API Status Cards -->
    <div class="row mb-4">
        <div class="col-md-2">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title">Device Management</h5>
                    <span class="badge bg-warning">Unavailable</span>
                    <p class="card-text mt-2">Devices: 0</p>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title">Data Acquisition</h5>
                    <span class="badge bg-warning">Unavailable</span>
                    <p class="card-text mt-2">Data Points: 0</p>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title">Connection Management</h5>
                    <span class="badge bg-warning">Unavailable</span>
                    <p class="card-text mt-2">Connected: 0/0</p>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title">Project Management</h5>
                    <span class="badge bg-warning">Unavailable</span>
                    <p class="card-text mt-2">Active: 0/0</p>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title">Communication</h5>
                    <span class="badge bg-warning">Unavailable</span>
                    <p class="card-text mt-2">Links: 0/0</p>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title">System Status</h5>
                    <div class="row">
                        <div class="col-6">
                            <h3 class="text-primary">0</h3>
                            <small>Total Drivers</small>
                        </div>
                        <div class="col-6">
                            <h3 class="text-success">0</h3>
                            <small>Connected</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row">
        <div class="col-lg-6">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Quick Actions</h5>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <button class="btn btn-outline-primary" @onclick='() => Navigation.NavigateTo("/device-management")'>
                            <i class="bi bi-cpu me-1"></i>Manage Devices
                        </button>
                        <button class="btn btn-outline-success" @onclick='() => Navigation.NavigateTo("/drivers")'>
                            <i class="bi bi-gear me-1"></i>Configure Drivers
                        </button>
                        <button class="btn btn-outline-info" @onclick='() => Navigation.NavigateTo("/monitoring")'>
                            <i class="bi bi-graph-up me-1"></i>Monitor Data
                        </button>
                        <button class="btn btn-outline-warning" @onclick='() => Navigation.NavigateTo("/settings")'>
                            <i class="bi bi-gear-fill me-1"></i>Settings
                        </button>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">System Information</h5>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-4">Version:</dt>
                        <dd class="col-sm-8">2.0.0-beta</dd>
                        
                        <dt class="col-sm-4">Build:</dt>
                        <dd class="col-sm-8">DDD Architecture</dd>
                        
                        <dt class="col-sm-4">Status:</dt>
                        <dd class="col-sm-8"><span class="badge bg-success">Operational</span></dd>
                        
                        <dt class="col-sm-4">Uptime:</dt>
                        <dd class="col-sm-8">@GetUptime()</dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private readonly DateTime _startTime = DateTime.Now;

    private void ConnectAll()
    {
        Logger.LogInformation("Connect All requested");
        // Implementation for connecting all drivers
    }

    private void DisconnectAll()
    {
        Logger.LogInformation("Disconnect All requested");
        // Implementation for disconnecting all drivers
    }

    private string GetUptime()
    {
        var uptime = DateTime.Now - _startTime;
        return $"{uptime.Hours:D2}:{uptime.Minutes:D2}:{uptime.Seconds:D2}";
    }
}